<title>Agrupamento 97 · IECA – Rev. José Belo Chipenda</title>
<link rel="icon" type="image/jpeg" href="logo.jpeg">
<style>
  :root{
    --lilas: #7030A0;
    --lilas-escuro: #4A1D6E;
    --lilas-suave: #F3EAFB;
    --dourado: #E0A335;
    --branco: #FFFFFF;
    --texto: #2B2233;
    --texto-suave: #6E6178;
    --linha: #E4D9F2;
    --erro: #C0392B;
    --ok: #2E8B57;
    --font-display: 'Poppins', 'Segoe UI', sans-serif;
    --font-body: 'Inter', 'Segoe UI', sans-serif;
    --font-mono: 'Fira Code', 'Consolas', monospace;
    --raio: 14px;
    --sombra: 0 8px 24px rgba(74,29,110,0.10);
  }

  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    font-family: var(--font-body);
    background: var(--lilas-suave);
    color: var(--texto);
    min-height:100vh;
    display:flex;
  }

  /* ===== SIDEBAR ===== */
  .sidebar{
    width:250px;
    background: linear-gradient(180deg, var(--lilas-escuro), var(--lilas));
    color:var(--branco);
    display:flex;
    flex-direction:column;
    position:fixed;
    top:0; left:0; bottom:0;
    z-index:50;
    transition: transform .3s ease;
  }
  .brand{
    display:flex;
    align-items:center;
    gap:10px;
    padding:22px 18px;
    border-bottom:1px solid rgba(255,255,255,0.15);
  }
  .brand .logo-img{flex-shrink:0; width:44px; height:44px; object-fit:cover; border-radius:50%; background:var(--branco); border:2px solid rgba(255,255,255,0.6);}
  .brand-text{line-height:1.15;}
  .brand-text .num{font-family:var(--font-display); font-weight:700; font-size:1.05rem; letter-spacing:.5px;}
  .brand-text .sub{font-size:.68rem; opacity:.8; text-transform:uppercase; letter-spacing:.6px;}

  nav.menu{flex:1; padding:14px 10px; overflow-y:auto;}
  .menu-label{font-size:.68rem; text-transform:uppercase; letter-spacing:.8px; opacity:.6; padding:14px 12px 6px;}
  .menu button{
    width:100%;
    text-align:left;
    background:transparent;
    border:none;
    color:rgba(255,255,255,0.88);
    font-family:var(--font-body);
    font-size:.9rem;
    padding:10px 12px;
    border-radius:10px;
    display:flex;
    align-items:center;
    gap:10px;
    cursor:pointer;
    transition:.15s;
    margin-bottom:2px;
  }
  .menu button:hover{background:rgba(255,255,255,0.10);}
  .menu button.active{background:var(--branco); color:var(--lilas-escuro); font-weight:600;}
  .menu button .ico{width:18px; text-align:center; font-size:1rem;}

  .sidebar-foot{
    padding:14px 18px;
    font-size:.68rem;
    opacity:.65;
    border-top:1px solid rgba(255,255,255,0.15);
  }

  /* ===== MAIN ===== */
  .main{margin-left:250px; flex:1; min-height:100vh;}
  .topbar{
    background:var(--branco);
    padding:16px 32px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    border-bottom:1px solid var(--linha);
    position:sticky; top:0; z-index:40;
  }
  .topbar h1{font-family:var(--font-display); font-size:1.15rem; color:var(--lilas-escuro);}
  .topbar .data-hoje{font-size:.8rem; color:var(--texto-suave);}
  .menu-toggle{display:none; background:none; border:none; font-size:1.4rem; color:var(--lilas-escuro); cursor:pointer;}

  .conteudo{padding:32px; max-width:1180px;}
  .pagina{display:none; animation: entra .35s ease;}
  .pagina.active{display:block;}
  @keyframes entra{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}

  /* ===== HOME ===== */
  .hero{
    background: linear-gradient(120deg, var(--lilas) 0%, var(--lilas-escuro) 100%);
    border-radius: 22px;
    padding: 46px 40px;
    color:var(--branco);
    position:relative;
    overflow:hidden;
    margin-bottom:30px;
  }
  .hero::after{
    content:"";
    position:absolute; right:-60px; top:-60px;
    width:260px; height:260px;
    background: radial-gradient(circle, rgba(224,163,53,0.35), transparent 70%);
  }
  .hero .logo-marca{
    position:absolute; right:34px; top:50%; transform:translateY(-50%);
    width:130px; height:130px; border-radius:50%;
    object-fit:cover; border:4px solid rgba(255,255,255,0.85);
    box-shadow:0 10px 26px rgba(0,0,0,0.25);
  }
  @media (max-width:760px){ .hero .logo-marca{display:none;} }
  .hero .eyebrow{font-size:.75rem; letter-spacing:1.5px; text-transform:uppercase; opacity:.8; margin-bottom:8px;}
  .hero h2{font-family:var(--font-display); font-size:2rem; margin-bottom:10px; max-width:640px;}
  .hero p{max-width:560px; opacity:.92; line-height:1.55; font-size:.95rem;}

  .trilha{
    display:flex;
    gap:14px;
    margin-top:28px;
    flex-wrap:wrap;
  }
  .trilha .etapa{
    background:rgba(255,255,255,0.12);
    border:1px solid rgba(255,255,255,0.25);
    border-radius:12px;
    padding:10px 14px;
    font-size:.78rem;
    display:flex;
    align-items:center;
    gap:8px;
  }
  .trilha .etapa b{font-family:var(--font-mono); color:var(--dourado);}

  .atalhos{display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:16px; margin-bottom:10px;}
  .atalho-card{
    background:var(--branco);
    border-radius:var(--raio);
    padding:20px;
    box-shadow:var(--sombra);
    cursor:pointer;
    transition:.2s;
    border:1px solid var(--linha);
  }
  .atalho-card:hover{transform:translateY(-3px); border-color:var(--lilas);}
  .atalho-card .ico{font-size:1.5rem; margin-bottom:8px;}
  .atalho-card h3{font-family:var(--font-display); font-size:.95rem; margin-bottom:4px; color:var(--lilas-escuro);}
  .atalho-card p{font-size:.78rem; color:var(--texto-suave);}

  /* ===== SECÇÃO GENÉRICA ===== */
  .cabecalho-pagina{display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:22px; flex-wrap:wrap; gap:10px;}
  .cabecalho-pagina h2{font-family:var(--font-display); font-size:1.4rem; color:var(--lilas-escuro);}
  .cabecalho-pagina p{color:var(--texto-suave); font-size:.85rem; margin-top:4px;}

  .btn{
    background:var(--lilas);
    color:var(--branco);
    border:none;
    padding:10px 18px;
    border-radius:10px;
    font-size:.85rem;
    font-weight:600;
    cursor:pointer;
    transition:.15s;
  }
  .btn:hover{background:var(--lilas-escuro);}
  .btn.dourado{background:var(--dourado); color:var(--texto);}
  .btn.dourado:hover{background:#c98d24;}
  .btn.secundario{background:var(--branco); color:var(--lilas); border:1.5px solid var(--lilas);}

  .cartao{background:var(--branco); border-radius:var(--raio); box-shadow:var(--sombra); border:1px solid var(--linha); overflow:hidden;}

  table{width:100%; border-collapse:collapse; font-size:.85rem;}
  thead{background:var(--lilas-suave);}
  th{text-align:left; padding:12px 16px; color:var(--lilas-escuro); font-weight:600; font-size:.75rem; text-transform:uppercase; letter-spacing:.4px;}
  td{padding:12px 16px; border-top:1px solid var(--linha);}
  tbody tr:hover{background:#FBF8FE;}

  .badge{padding:4px 10px; border-radius:20px; font-size:.72rem; font-weight:600; display:inline-block;}
  .badge.lobitinhos{background:#FDECE3; color:#C0622B;}
  .badge.juniores{background:#E3F1FD; color:#2470A8;}
  .badge.seniores{background:#EAFBEF; color:#2E8B57;}
  .badge.caminheiros{background:#F3EAFB; color:var(--lilas-escuro);}
  .badge.dirigentes{background:#FEF6E0; color:#A87B12;}
  .badge.ativo{background:#EAFBEF; color:var(--ok);}
  .badge.pendente{background:#FEF3E0; color:#B9770E;}
  .badge.pago{background:#EAFBEF; color:var(--ok);}

  .grid-secoes{display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:18px; margin-bottom:26px;}
  .secao-card{background:var(--branco); border-radius:var(--raio); box-shadow:var(--sombra); padding:22px; border-top:5px solid var(--lilas);}
  .secao-card.lobitinhos{border-color:#E0793A;}
  .secao-card.juniores{border-color:#2E8FCB;}
  .secao-card.seniores{border-color:#2E8B57;}
  .secao-card.caminheiros{border-color:var(--lilas);}
  .secao-card.dirigentes{border-color:var(--dourado);}
  .secao-card h3{font-family:var(--font-display); font-size:1rem; margin-bottom:4px; color:var(--texto);}
  .secao-card .faixa{font-family:var(--font-mono); font-size:.78rem; color:var(--texto-suave); margin-bottom:10px;}
  .secao-card .contagem{font-size:1.8rem; font-weight:700; font-family:var(--font-display); color:var(--lilas-escuro);}
  .secao-card .contagem span{font-size:.75rem; font-weight:400; color:var(--texto-suave); font-family:var(--font-body);}

  form.formulario{background:var(--branco); border-radius:var(--raio); box-shadow:var(--sombra); padding:26px; border:1px solid var(--linha); margin-bottom:26px; display:none;}
  form.formulario.aberto{display:grid; grid-template-columns:1fr 1fr; gap:16px;}
  form.formulario .campo-full{grid-column:1/-1;}
  form.formulario label{display:block; font-size:.78rem; font-weight:600; color:var(--texto-suave); margin-bottom:6px;}
  form.formulario input, form.formulario select{
    width:100%; padding:10px 12px; border-radius:8px; border:1.5px solid var(--linha);
    font-family:var(--font-body); font-size:.88rem; color:var(--texto); background:#FBFAFD;
  }
  form.formulario input:focus, form.formulario select:focus{outline:none; border-color:var(--lilas);}
  form.formulario .acoes-form{grid-column:1/-1; display:flex; gap:10px; justify-content:flex-end; margin-top:6px;}

  .toolbar{display:flex; gap:10px; margin-bottom:18px; flex-wrap:wrap; align-items:center;}
  .toolbar input[type=text]{padding:9px 14px; border-radius:8px; border:1.5px solid var(--linha); font-size:.85rem; min-width:220px; background:var(--branco);}

  .areas-lista{display:grid; grid-template-columns:repeat(auto-fit,minmax(230px,1fr)); gap:16px;}
  .area-card{background:var(--branco); border-radius:var(--raio); box-shadow:var(--sombra); padding:18px; border-left:5px solid var(--dourado);}
  .area-card h4{font-family:var(--font-display); font-size:.92rem; color:var(--lilas-escuro); margin-bottom:6px;}
  .area-card p{font-size:.8rem; color:var(--texto-suave); line-height:1.5;}

  .resumo-financeiro{display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:16px; margin-bottom:22px;}
  .resumo-item{background:var(--branco); border-radius:var(--raio); box-shadow:var(--sombra); padding:18px;}
  .resumo-item .rotulo{font-size:.72rem; text-transform:uppercase; letter-spacing:.5px; color:var(--texto-suave); margin-bottom:6px;}
  .resumo-item .valor{font-family:var(--font-display); font-size:1.4rem; color:var(--lilas-escuro); font-weight:700;}
  .resumo-item.receber .valor{color:var(--erro);}

  .vazio{padding:40px; text-align:center; color:var(--texto-suave); font-size:.88rem;}

  footer.rodape{padding:24px 32px; text-align:center; font-size:.75rem; color:var(--texto-suave);}

  ::placeholder{color:#B7A9C9;}

  @media (max-width:920px){
    .sidebar{transform:translateX(-100%);}
    .sidebar.aberta{transform:translateX(0);}
    .main{margin-left:0;}
    .menu-toggle{display:block;}
    form.formulario.aberto{grid-template-columns:1fr;}
  }
</style>
</head>
