  <div class="sidebar-foot">© 2026 Agrupamento 97 — IECA<br>Rev. José Belo Chipenda</div>
</aside>

<!-- ===================== MAIN ===================== -->
<div class="main">
  <div class="topbar">
    <div style="display:flex; align-items:center; gap:12px;">
      <button class="menu-toggle" id="menuToggle">☰</button>
      <h1 id="tituloPagina">Início</h1>
    </div>
    <div class="data-hoje" id="dataHoje"></div>
  </div>

  <div class="conteudo">

    <!-- ===================== HOME ===================== -->
    <section class="pagina active" id="page-home">
      <div class="hero">
        <img src="https://scontent.flad7-1.fna.fbcdn.net/v/t39.30808-6/738271030_27415498748121635_5504532128612609037_n.jpg?stp=dst-jpg_tt6&cstp=mx640x640&ctp=p526x296&_nc_cat=105&ccb=1-7&_nc_sid=aa7b47&_nc_eui2=AeHB34hnlWBpqU7_Cmcp5C0gj8yVwZA1lKiPzJXBkDWUqBvWpxy_biISqmmo7dm50KVpGb4WHxClKgwvB9-ezy49&_nc_ohc=HyJKnMHNqywQ7kNvwEdNUH7&_nc_oc=AdqoWqQoJV1MtXl7leGVJEB-nX-bQ1uyghWr6pGsXnlZy8T9_RZBo6YlvmWmc9x2rwk&_nc_zt=23&_nc_ht=scontent.flad7-1.fna&_nc_gid=vizwg9Mpzp-HRnM209FUPg&_nc_ss=7c2a8&oh=00_AQAtzOxfVplOY8n6wL1E8godO55LKk8KOQVzHXQ3xhxRhw&oe=6A4DB53F" width="100%" alt="https://scontent.flad7-1.fna.fbcdn.net/v/t39.30808-6/738271030_27415498748121635_5504532128612609037_n.jpg?stp=dst-jpg_tt6&cstp=mx640x640&ctp=p526x296&_nc_cat=105&ccb=1-7&_nc_sid=aa7b47&_nc_eui2=AeHB34hnlWBpqU7_Cmcp5C0gj8yVwZA1lKiPzJXBkDWUqBvWpxy_biISqmmo7dm50KVpGb4WHxClKgwvB9-ezy49&_nc_ohc=HyJKnMHNqywQ7kNvwEdNUH7&_nc_oc=AdqoWqQoJV1MtXl7leGVJEB-nX-bQ1uyghWr6pGsXnlZy8T9_RZBo6YlvmWmc9x2rwk&_nc_zt=23&_nc_ht=scontent.flad7-1.fna&_nc_gid=vizwg9Mpzp-HRnM209FUPg&_nc_ss=7c2a8&oh=00_AQAtzOxfVplOY8n6wL1E8godO55LKk8KOQVzHXQ3xhxRhw&oe=6A4DB53F" class="logo-marca">
        <div class="eyebrow">Bem-vindo(a) ao</div>
        <h2>Agrupamento 97 – IECA<br>Rev. José Belo Chipenda</h2>
        <p>Um espaço de formação de caráter, fé e cidadania, acompanhando cada Escuteiro desde os Lobitinhos até aos Caminheiros. Aqui geres secções, cadastros, dirigentes e finanças do agrupamento num só lugar.</p>
        <div class="trilha">
          <div class="etapa">🐺 <b>2–9</b> Lobitinhos</div>
          <div class="etapa">🧭 <b>10–13</b> Exploradores Júniores</div>
          <div class="etapa">🏕️ <b>14–17</b> Exploradores Seniores</div>
          <div class="etapa">🎒 <b>18–23</b> Caminheiros</div>
        </div>
      </div>

      <div class="cabecalho-pagina"><h2>Atalhos rápidos</h2></div>
      <div class="atalhos">
        <div class="atalho-card" data-page="escuteiros"><div class="ico">🧭</div><h3>Escuteiros</h3><p>Consultar e cadastrar Escuteiros de todas as secções.</p></div>
        <div class="atalho-card" data-page="dirigentes"><div class="ico">🎖️</div><h3>Dirigentes</h3><p>Gerir os adultos responsáveis por cada secção.</p></div>
        <div class="atalho-card" data-page="secretaria"><div class="ico">🗂️</div><h3>Secretaria</h3><p>Novo cadastramento e inscrição no movimento.</p></div>
        <div class="atalho-card" data-page="tesouraria"><div class="ico">💰</div><h3>Tesouraria</h3><p>Inscrições, mensalidades e pagamentos de atividades.</p></div>
      </div>
    </section>

    <!-- ===================== ESCUTEIROS ===================== -->
    <section class="pagina" id="page-escuteiros">
      <div class="cabecalho-pagina">
        <div><h2>Escuteiros</h2><p>Todos os membros do agrupamento, dos Lobitinhos aos Caminheiros.</p></div>
        <button class="btn" onclick="toggleForm('form-escuteiro')">+ Novo Escuteiro</button>
      </div>

      <form class="formulario" id="form-escuteiro" onsubmit="adicionarEscuteiro(event)">
        <div><label>Nome completo</label><input required id="esc-nome" type="text" placeholder="Nome do Escuteiro"></div>
        <div><label>Data de nascimento</label><input required id="esc-nasc" type="date"></div>
        <div><label>Encarregado de Educação</label><input required id="esc-enc" type="text" placeholder="Nome do encarregado"></div>
        <div><label>Contacto</label><input required id="esc-contacto" type="text" placeholder="Nº de telefone"></div>
        <div class="campo-full acoes-form">
          <button type="button" class="btn secundario" onclick="toggleForm('form-escuteiro')">Cancelar</button>
          <button type="submit" class="btn dourado">Guardar Escuteiro</button>
        </div>
      </form>

      <div class="toolbar">
        <input type="text" id="filtro-escuteiro" placeholder="Pesquisar por nome..." oninput="renderEscuteiros()">
        <select id="filtro-secao-escuteiro" onchange="renderEscuteiros()">
          <option value="">Todas as secções</option>
          <option value="Lobitinhos">Lobitinhos</option>
          <option value="Exploradores Júniores">Exploradores Júniores</option>
          <option value="Exploradores Seniores">Exploradores Seniores</option>
          <option value="Caminheiros">Caminheiros</option>
        </select>
      </div>

      <div class="cartao">
        <table>
          <thead><tr><th>Nome</th><th>Idade</th><th>Secção</th><th>Encarregado</th><th>Contacto</th><th>Estado</th></tr></thead>
          <tbody id="tabela-escuteiros"></tbody>
        </table>
      </div>
    </section>

    <!-- ===================== DIRIGENTES ===================== -->
    <section class="pagina" id="page-dirigentes">
      <div class="cabecalho-pagina">
        <div><h2>Dirigentes</h2><p>Adultos responsáveis por acompanhar os Escuteiros em cada secção.</p></div>
        <button class="btn" onclick="toggleForm('form-dirigente')">+ Novo Dirigente</button>
      </div>

      <form class="formulario" id="form-dirigente" onsubmit="adicionarDirigente(event)">
        <div><label>Nome completo</label><input required id="dir-nome" type="text" placeholder="Nome do dirigente"></div>
        <div><label>Função</label>
          <select required id="dir-funcao">
            <option value="Chefe de Secção">Chefe de Secção</option>
            <option value="Subchefe">Subchefe</option>
            <option value="Capelão">Capelão</option>
            <option value="Chefe de Agrupamento">Chefe de Agrupamento</option>
            <option value="Secretário(a)">Secretário(a)</option>
            <option value="Tesoureiro(a)">Tesoureiro(a)</option>
          </select>
        </div>
        <div><label>Secção que acompanha</label>
          <select required id="dir-secao">
            <option value="Lobitinhos">Lobitinhos</option>
            <option value="Exploradores Júniores">Exploradores Júniores</option>
            <option value="Exploradores Seniores">Exploradores Seniores</option>
            <option value="Caminheiros">Caminheiros</option>
            <option value="Agrupamento">Agrupamento (todas)</option>
          </select>
        </div>
        <div><label>Contacto</label><input required id="dir-contacto" type="text" placeholder="Nº de telefone"></div>
        <div class="campo-full acoes-form">
          <button type="button" class="btn secundario" onclick="toggleForm('form-dirigente')">Cancelar</button>
          <button type="submit" class="btn dourado">Guardar Dirigente</button>
        </div>
      </form>

      <div class="cartao">
        <table>
          <thead><tr><th>Nome</th><th>Função</th><th>Secção</th><th>Contacto</th><th>Estado</th></tr></thead>
          <tbody id="tabela-dirigentes"></tbody>
        </table>
      </div>
    </section>

    <!-- ===================== SECÇÕES ===================== -->
    <section class="pagina" id="page-secoes">
      <div class="cabecalho-pagina"><div><h2>Secções</h2><p>Estrutura etária do agrupamento — cada Escuteiro é automaticamente enquadrado pela idade.</p></div></div>
      <div class="grid-secoes" id="grid-secoes"></div>
    </section>

    <!-- ===================== ÁREAS DE DESENVOLVIMENTO ===================== -->
    <section class="pagina" id="page-areas">
      <div class="cabecalho-pagina">
        <div><h2>Áreas de Desenvolvimento Escutista</h2><p>Substituem as antigas "Disciplinas" — as dimensões trabalhadas com os Escuteiros em cada etapa.</p></div>
      </div>
      <div class="areas-lista">
        <div class="area-card"><h4>🕊️ Espiritual</h4><p>Formação de fé e valores cristãos, alinhados à missão da IECA.</p></div>
        <div class="area-card"><h4>💪 Físico</h4><p>Saúde, vida ao ar livre e desenvolvimento corporal.</p></div>
        <div class="area-card"><h4>📚 Intelectual</h4><p>Curiosidade, resolução de problemas e aprendizagem contínua.</p></div>
        <div class="area-card"><h4>❤️ Afetivo</h4><p>Equilíbrio emocional e relações saudáveis.</p></div>
        <div class="area-card"><h4>🤝 Social</h4><p>Trabalho em equipa, serviço comunitário e cidadania.</p></div>
        <div class="area-card"><h4>🧭 Caráter</h4><p>Responsabilidade, honestidade e autodisciplina, guiadas pela Lei do Escuteiro.</p></div>
      </div>
    </section>

    <!-- ===================== SECRETARIA ===================== -->
    <section class="pagina" id="page-secretaria">
      <div class="cabecalho-pagina"><div><h2>Secretaria</h2><p>Cadastramento e inscrição de novos membros no movimento.</p></div></div>

      <form class="formulario aberto" id="form-secretaria" onsubmit="cadastrarNovoMembro(event)">
        <div><label>Nome completo</label><input required id="sec-nome" type="text" placeholder="Nome completo"></div>
        <div><label>Data de nascimento</label><input required id="sec-nasc" type="date"></div>
        <div><label>Tipo de membro</label>
          <select id="sec-tipo" onchange="alternarCamposSecretaria()">
            <option value="escuteiro">Escuteiro</option>
            <option value="dirigente">Dirigente</option>
          </select>
        </div>
        <div id="sec-campo-enc"><label>Encarregado de Educação</label><input id="sec-enc" type="text" placeholder="Nome do encarregado"></div>
        <div><label>Contacto</label><input required id="sec-contacto" type="text" placeholder="Nº de telefone"></div>
        <div><label>Bilhete de Identidade / Cédula</label><input id="sec-doc" type="text" placeholder="Nº do documento"></div>
        <div class="campo-full acoes-form">
          <button type="reset" class="btn secundario">Limpar</button>
          <button type="submit" class="btn dourado">Concluir Cadastramento</button>
        </div>
      </form>

      <div class="cartao">
        <table>
          <thead><tr><th>Nome</th><th>Tipo</th><th>Idade / Secção</th><th>Contacto</th><th>Data de cadastro</th></tr></thead>
          <tbody id="tabela-cadastros"></tbody>
        </table>
      </div>
    </section>

    <!-- ===================== TESOURARIA ===================== -->
    <section class="pagina" id="page-tesouraria">
      <div class="cabecalho-pagina">
        <div><h2>Tesouraria</h2><p>Inscrições, mensalidades e pagamentos de atividades do agrupamento.</p></div>
        <button class="btn" onclick="toggleForm('form-pagamento')">+ Novo Pagamento</button>
      </div>

      <div class="resumo-financeiro">
        <div class="resumo-item"><div class="rotulo">Total recebido</div><div class="valor" id="res-recebido">0 Kz</div></div>
        <div class="resumo-item receber"><div class="rotulo">Pendente</div><div class="valor" id="res-pendente">0 Kz</div></div>
        <div class="resumo-item"><div class="rotulo">Nº de lançamentos</div><div class="valor" id="res-total">0</div></div>
      </div>

      <form class="formulario" id="form-pagamento" onsubmit="adicionarPagamento(event)">
        <div><label>Nome</label><input required id="pag-nome" type="text" placeholder="Escuteiro / Dirigente"></div>
        <div><label>Tipo de pagamento</label>
          <select id="pag-tipo">
            <option>Inscrição no Movimento</option>
            <option>Mensalidade</option>
            <option>Atividade / Acampamento</option>
            <option>Uniforme</option>
          </select>
        </div>
        <div><label>Valor (Kz)</label><input required id="pag-valor" type="number" min="0" placeholder="0"></div>
        <div><label>Data</label><input required id="pag-data" type="date"></div>
        <div><label>Estado</label>
          <select id="pag-estado"><option value="Pago">Pago</option><option value="Pendente">Pendente</option></select>
        </div>
        <div class="campo-full acoes-form">
          <button type="button" class="btn secundario" onclick="toggleForm('form-pagamento')">Cancelar</button>
          <button type="submit" class="btn dourado">Registar Pagamento</button>
        </div>
      </form>

      <div class="cartao">
        <table>
          <thead><tr><th>Nome</th><th>Tipo</th><th>Valor</th><th>Data</th><th>Estado</th></tr></thead>
          <tbody id="tabela-pagamentos"></tbody>
        </table>
      </div>
    </section>

  </div>

  <footer class="rodape">Agrupamento 97 · IECA — Rev. José Belo Chipenda &nbsp;|&nbsp; Sistema de Gestão Escutista</footer>
</div>

<script>
/* ===================== DADOS (em memória) ===================== */
let escuteiros = [
  {nome:"Manuel António", nasc:"2019-03-12", encarregado:"Isabel António", contacto:"923 111 222", estado:"Ativo"},
  {nome:"Beatriz Kiala", nasc:"2014-07-02", encarregado:"João Kiala", contacto:"924 222 333", estado:"Ativo"},
  {nome:"Domingos Sachipengo", nasc:"2010-11-20", encarregado:"Maria Sachipengo", contacto:"925 333 444", estado:"Ativo"},
  {nome:"Ester Chipenda", nasc:"2006-01-15", encarregado:"—", contacto:"926 444 555", estado:"Ativo"},
];

let dirigentes = [
  {nome:"Pastor Ndalu Chipenda", funcao:"Chefe de Agrupamento", secao:"Agrupamento", contacto:"927 555 666", estado:"Ativo"},
  {nome:"Sara Bumba", funcao:"Chefe de Secção", secao:"Lobitinhos", contacto:"928 666 777", estado:"Ativo"},
  {nome:"Pedro Vunge", funcao:"Chefe de Secção", secao:"Exploradores Júniores", contacto:"929 777 888", estado:"Ativo"},
];

let cadastros = [];
let pagamentos = [
  {nome:"Manuel António", tipo:"Inscrição no Movimento", valor:5000, data:"2026-02-10", estado:"Pago"},
  {nome:"Beatriz Kiala", tipo:"Mensalidade", valor:1500, data:"2026-06-05", estado:"Pendente"},
];

/* ===================== NAVEGAÇÃO ===================== */
const titulos = {
  home:"Início", escuteiros:"Escuteiros", dirigentes:"Dirigentes", secoes:"Secções",
  areas:"Áreas de Desenvolvimento", secretaria:"Secretaria", tesouraria:"Tesouraria"
};

function irPara(pagina){
  document.querySelectorAll('.pagina').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+pagina).classList.add('active');
  document.querySelectorAll('.menu button').forEach(b=>b.classList.toggle('active', b.dataset.page===pagina));
  document.getElementById('tituloPagina').textContent = titulos[pagina];
  document.getElementById('sidebar').classList.remove('aberta');
}

document.querySelectorAll('.menu button, .atalho-card').forEach(el=>{
  el.addEventListener('click', ()=> irPara(el.dataset.page));
});

document.getElementById('menuToggle').addEventListener('click', ()=>{
  document.getElementById('sidebar').classList.toggle('aberta');
});

document.getElementById('dataHoje').textContent = new Date().toLocaleDateString('pt-PT', {weekday:'long', year:'numeric', month:'long', day:'numeric'});

function toggleForm(id){
  document.getElementById(id).classList.toggle('aberto');
}

/* ===================== LÓGICA DE IDADE / SECÇÃO ===================== */
function calcularIdade(dataNasc){
  const nasc = new Date(dataNasc);
  const hoje = new Date();
  let idade = hoje.getFullYear() - nasc.getFullYear();
  const m = hoje.getMonth() - nasc.getMonth();
  if(m < 0 || (m===0 && hoje.getDate() < nasc.getDate())) idade--;
  return idade;
}

function secaoPorIdade(idade){
  if(idade>=2 && idade<=9) return "Lobitinhos";
  if(idade>=10 && idade<=13) return "Exploradores Júniores";
  if(idade>=14 && idade<=17) return "Exploradores Seniores";
  if(idade>=18 && idade<=23) return "Caminheiros";
  return "Fora de faixa etária";
}

function classeBadgeSecao(secao){
  return {
    "Lobitinhos":"lobitinhos", "Exploradores Júniores":"juniores",
    "Exploradores Seniores":"seniores", "Caminheiros":"caminheiros"
  }[secao] || "";
}

/* ===================== ESCUTEIROS ===================== */
function renderEscuteiros(){
  const filtroTexto = document.getElementById('filtro-escuteiro').value.toLowerCase();
  const filtroSecao = document.getElementById('filtro-secao-escuteiro').value;
  const corpo = document.getElementById('tabela-escuteiros');
  corpo.innerHTML = '';

  const filtrados = escuteiros.filter(e=>{
    const idade = calcularIdade(e.nasc);
    const secao = secaoPorIdade(idade);
    const passaTexto = e.nome.toLowerCase().includes(filtroTexto);
    const passaSecao = !filtroSecao || secao === filtroSecao;
    return passaTexto && passaSecao;
  });

  if(filtrados.length===0){
    corpo.innerHTML = `<tr><td colspan="6" class="vazio">Nenhum Escuteiro encontrado.</td></tr>`;
    return;
  }

  filtrados.forEach(e=>{
    const idade = calcularIdade(e.nasc);
    const secao = secaoPorIdade(idade);
    corpo.innerHTML += `<tr>
      <td>${e.nome}</td>
      <td>${idade} anos</td>
      <td><span class="badge ${classeBadgeSecao(secao)}">${secao}</span></td>
      <td>${e.encarregado}</td>
      <td>${e.contacto}</td>
      <td><span class="badge ativo">${e.estado}</span></td>
    </tr>`;
  });
}

function adicionarEscuteiro(ev){
  ev.preventDefault();
  escuteiros.push({
    nome: document.getElementById('esc-nome').value,
    nasc: document.getElementById('esc-nasc').value,
    encarregado: document.getElementById('esc-enc').value,
    contacto: document.getElementById('esc-contacto').value,
    estado: "Ativo"
  });
  ev.target.reset();
  toggleForm('form-escuteiro');
  renderEscuteiros();
  renderSecoes();
}

/* ===================== DIRIGENTES ===================== */
function renderDirigentes(){
  const corpo = document.getElementById('tabela-dirigentes');
  corpo.innerHTML = '';
  if(dirigentes.length===0){
    corpo.innerHTML = `<tr><td colspan="5" class="vazio">Nenhum Dirigente cadastrado.</td></tr>`;
    return;
  }
  dirigentes.forEach(d=>{
    corpo.innerHTML += `<tr>
      <td>${d.nome}</td><td>${d.funcao}</td>
      <td><span class="badge dirigentes">${d.secao}</span></td>
      <td>${d.contacto}</td>
      <td><span class="badge ativo">${d.estado}</span></td>
    </tr>`;
  });
}

function adicionarDirigente(ev){
  ev.preventDefault();
  dirigentes.push({
    nome: document.getElementById('dir-nome').value,
    funcao: document.getElementById('dir-funcao').value,
    secao: document.getElementById('dir-secao').value,
    contacto: document.getElementById('dir-contacto').value,
    estado: "Ativo"
  });
  ev.target.reset();
  toggleForm('form-dirigente');
  renderDirigentes();
  renderSecoes();
}

/* ===================== SECÇÕES ===================== */
function renderSecoes(){
  const definicoes = [
    {chave:"Lobitinhos", faixa:"2 – 9 anos", classe:"lobitinhos", icone:"🐺"},
    {chave:"Exploradores Júniores", faixa:"10 – 13 anos", classe:"juniores", icone:"🧭"},
    {chave:"Exploradores Seniores", faixa:"14 – 17 anos", classe:"seniores", icone:"🏕️"},
    {chave:"Caminheiros", faixa:"18 – 23 anos", classe:"caminheiros", icone:"🎒"},
  ];
  const grid = document.getElementById('grid-secoes');
  grid.innerHTML = '';
  definicoes.forEach(d=>{
    const total = escuteiros.filter(e=> secaoPorIdade(calcularIdade(e.nasc)) === d.chave).length;
    grid.innerHTML += `<div class="secao-card ${d.classe}">
      <h3>${d.icone} ${d.chave}</h3>
      <div class="faixa">${d.faixa}</div>
      <div class="contagem">${total} <span>Escuteiros</span></div>
    </div>`;
  });
  const totalDirigentes = dirigentes.length;
  grid.innerHTML += `<div class="secao-card dirigentes">
    <h3>🎖️ Dirigentes</h3>
    <div class="faixa">Adultos acompanhantes</div>
    <div class="contagem">${totalDirigentes} <span>Dirigentes</span></div>
  </div>`;
}

/* ===================== SECRETARIA ===================== */
function alternarCamposSecretaria(){
  const tipo = document.getElementById('sec-tipo').value;
  document.getElementById('sec-campo-enc').style.display = tipo === 'dirigente' ? 'none' : 'block';
}

function renderCadastros(){
  const corpo = document.getElementById('tabela-cadastros');
  corpo.innerHTML = '';
  if(cadastros.length===0){
    corpo.innerHTML = `<tr><td colspan="5" class="vazio">Ainda não há novos cadastramentos.</td></tr>`;
    return;
  }
  cadastros.forEach(c=>{
    corpo.innerHTML += `<tr>
      <td>${c.nome}</td>
      <td>${c.tipo === 'escuteiro' ? 'Escuteiro' : 'Dirigente'}</td>
      <td>${c.detalheIdade}</td>
      <td>${c.contacto}</td>
      <td>${c.dataCadastro}</td>
    </tr>`;
  });
}

function cadastrarNovoMembro(ev){
  ev.preventDefault();
  const tipo = document.getElementById('sec-tipo').value;
  const nome = document.getElementById('sec-nome').value;
  const nasc = document.getElementById('sec-nasc').value;
  const contacto = document.getElementById('sec-contacto').value;
  const encarregado = document.getElementById('sec-enc').value || "—";
  const idade = calcularIdade(nasc);

  if(tipo === 'escuteiro'){
    escuteiros.push({nome, nasc, encarregado, contacto, estado:"Ativo"});
  } else {
    dirigentes.push({nome, funcao:"Dirigente", secao:"Agrupamento", contacto, estado:"Ativo"});
  }

  cadastros.unshift({
    nome, tipo, contacto,
    detalheIdade: tipo==='escuteiro' ? `${idade} anos · ${secaoPorIdade(idade)}` : 'Dirigente',
    dataCadastro: new Date().toLocaleDateString('pt-PT')
  });

  ev.target.reset();
  document.getElementById('sec-campo-enc').style.display = 'block';
  renderCadastros();
  renderEscuteiros();
  renderDirigentes();
  renderSecoes();
}

/* ===================== TESOURARIA ===================== */
function formatarKz(valor){
  return valor.toLocaleString('pt-PT') + " Kz";
}

function renderPagamentos(){
  const corpo = document.getElementById('tabela-pagamentos');
  corpo.innerHTML = '';
  let recebido = 0, pendente = 0;

  if(pagamentos.length===0){
    corpo.innerHTML = `<tr><td colspan="5" class="vazio">Nenhum pagamento registado.</td></tr>`;
  } else {
    pagamentos.forEach(p=>{
      if(p.estado === 'Pago') recebido += Number(p.valor); else pendente += Number(p.valor);
      corpo.innerHTML += `<tr>
        <td>${p.nome}</td><td>${p.tipo}</td><td>${formatarKz(Number(p.valor))}</td>
        <td>${new Date(p.data).toLocaleDateString('pt-PT')}</td>
        <td><span class="badge ${p.estado==='Pago'?'pago':'pendente'}">${p.estado}</span></td>
      </tr>`;
    });
  }
  document.getElementById('res-recebido').textContent = formatarKz(recebido);
  document.getElementById('res-pendente').textContent = formatarKz(pendente);
  document.getElementById('res-total').textContent = pagamentos.length;
}

function adicionarPagamento(ev){
  ev.preventDefault();
  pagamentos.push({
    nome: document.getElementById('pag-nome').value,
    tipo: document.getElementById('pag-tipo').value,
    valor: document.getElementById('pag-valor').value,
    data: document.getElementById('pag-data').value,
    estado: document.getElementById('pag-estado').value
  });
  ev.target.reset();
  toggleForm('form-pagamento');
  renderPagamentos();
}

/* ===================== INICIALIZAÇÃO ===================== */
renderEscuteiros();
renderDirigentes();
renderSecoes();
renderCadastros();
renderPagamentos();
</script>
</body>
</html>
