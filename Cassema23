  <div class="brand">
    <img src="https://scontent.flad7-1.fna.fbcdn.net/v/t39.30808-6/738271030_27415498748121635_5504532128612609037_n.jpg?stp=dst-jpg_tt6&cstp=mx640x640&ctp=p526x296&_nc_cat=105&ccb=1-7&_nc_sid=aa7b47&_nc_eui2=AeHB34hnlWBpqU7_Cmcp5C0gj8yVwZA1lKiPzJXBkDWUqBvWpxy_biISqmmo7dm50KVpGb4WHxClKgwvB9-ezy49&_nc_ohc=HyJKnMHNqywQ7kNvwEdNUH7&_nc_oc=AdqoWqQoJV1MtXl7leGVJEB-nX-bQ1uyghWr6pGsXnlZy8T9_RZBo6YlvmWmc9x2rwk&_nc_zt=23&_nc_ht=scontent.flad7-1.fna&_nc_gid=vizwg9Mpzp-HRnM209FUPg&_nc_ss=7c2a8&oh=00_AQAtzOxfVplOY8n6wL1E8godO55LKk8KOQVzHXQ3xhxRhw&oe=6A4DB53F" width="100%" alt="Logo do Agrupamento 97" class="logo-img">
